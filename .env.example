# Copy to `.env.local` — Supabase → Project Settings → API Keys
#
# URL: project root only (no /rest/v1/)
#   https://YOUR_PROJECT_REF.supabase.co
#
# This variable accepts EITHER:
#   - Publishable key (new): sb_publishable_...
#   - anon JWT (legacy tab): eyJ...
# Use the Publishable OR anon key — never the Secret / service_role key in the browser.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=paste_publishable_or_legacy_anon_here

# Doimiy demo admin (email/parol + SQL): supabase/dev_admin.sql faylini oching.
#
# Cloud bazada profiles 404 / PGRST205: supabase/REMOTE_SETUP.sql ni SQL Editor’da bir marta Run qiling.
# Eski bazalar: admin o‘quvchini sinfga biriktira olmasa → supabase/migrations/20260426120000_admin_student_class.sql
#
# Parolni tiklash: Supabase → Authentication → URL Configuration
#   Site URL: http://localhost:5173 (yoki prod domen)
#   Redirect URLs: http://localhost:5173/auth/update-password (prod uchun ham mos qator)
